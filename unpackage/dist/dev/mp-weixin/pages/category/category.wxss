/**
 * 刷题小程序 - 主题变量配置
 * 用于 uView Plus UI 主题定制
 */
.category-container.data-v-8145b772 {
  min-height: 100vh;
  background-color: #f5f5f5;
}
.search-section.data-v-8145b772 {
  background: #fff;
  padding: 20rpx 30rpx;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 100;
}
.search-section .search-box.data-v-8145b772 {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
}
.search-section .search-box .search-icon.data-v-8145b772 {
  font-size: 32rpx;
  margin-right: 16rpx;
}
.search-section .search-box .search-input.data-v-8145b772 {
  flex: 1;
  height: 40rpx;
  font-size: 28rpx;
}
.category-scroll.data-v-8145b772 {
  height: calc(100vh - 120rpx);
  padding: 20rpx;
}
.category-grid.data-v-8145b772 {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.category-grid.data-v-8145b772::after {
  content: "";
  width: 48%;
}
.category-card.data-v-8145b772 {
  width: 48%;
  height: 280rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.category-card .card-content .card-icon.data-v-8145b772 {
  display: block;
  font-size: 56rpx;
  margin-bottom: 16rpx;
}
.category-card .card-content .card-name.data-v-8145b772 {
  display: block;
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.category-card .card-content .card-count.data-v-8145b772 {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}
.category-card .card-progress .progress-bar.data-v-8145b772 {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  margin-bottom: 8rpx;
  overflow: hidden;
}
.category-card .card-progress .progress-bar .progress-fill.data-v-8145b772 {
  height: 100%;
  background: #fff;
  border-radius: 4rpx;
  transition: width 0.3s;
}
.category-card .card-progress .progress-text.data-v-8145b772 {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}
.empty-state.data-v-8145b772 {
  text-align: center;
  padding: 100rpx 40rpx;
}
.empty-state .empty-icon.data-v-8145b772 {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}
.empty-state .empty-text.data-v-8145b772 {
  font-size: 30rpx;
  color: #999;
}